generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Empresa {
  id                   Int       @id @default(autoincrement())
  slug                 String    @unique
  nome                 String
  logoUrl              String?   @map("logo_url")
  /// WhatsApp do dono/barbearia (só dígitos, com DDI 55) para alertas de agenda
  whatsappNotificacoes String?   @map("whatsapp_notificacoes")
  unidades             Unidade[]

  @@map("empresas")
}

model Unidade {
  id           Int           @id @default(autoincrement())
  empresaId    Int           @map("empresa_id")
  nome         String
  funcionarios Funcionario[]
  servicos     Servico[]
  empresa      Empresa       @relation(fields: [empresaId], references: [id])

  @@map("unidades")
}

model Servico {
  id           Int           @id @default(autoincrement())
  unidadeId    Int           @map("unidade_id")
  nome         String
  preco        Float
  duracaoMin   Int?          @map("duracao_min")
  agendamentos Agendamento[]
  unidade      Unidade       @relation(fields: [unidadeId], references: [id])

  @@map("servicos")
}

model Funcionario {
  id               Int               @id @default(autoincrement())
  unidadeId        Int               @map("unidade_id")
  nome             String
  fotoUrl          String?           @map("foto_url")
  agendamentos     Agendamento[]
  disponibilidades Disponibilidade[]
  unidade          Unidade           @relation(fields: [unidadeId], references: [id])

  @@map("funcionarios")
}

model Disponibilidade {
  id            Int         @id @default(autoincrement())
  funcionarioId Int         @map("funcionario_id")
  diaSemana     Int         @map("dia_semana")
  horaInicio    String      @map("hora_inicio")
  horaFim       String      @map("hora_fim")
  funcionario   Funcionario @relation(fields: [funcionarioId], references: [id])

  @@map("disponibilidades")
}

model Agendamento {
  id                           Int         @id @default(autoincrement())
  servicoId                    Int         @map("servico_id")
  funcionarioId                Int         @map("funcionario_id")
  clienteId                    Int?        @map("cliente_id")
  data                         String
  hora                         String
  nomeCliente                  String      @map("nome_cliente")
  telefone                     String
  status                       String      @default("confirmado")
  /// Preenchido ao cancelar; usado para sumir do histórico após o período de graça
  canceladoAt                  DateTime?   @map("cancelado_at")
  createdAt                    DateTime    @default(now()) @map("created_at")
  confirmacaoWhatsappEnviadaAt DateTime?   @map("confirmacao_whatsapp_enviada_at")
  lembrete1hEnviadoAt          DateTime?   @map("lembrete_1h_enviado_at")
  lembrete30mEnviadoAt         DateTime?   @map("lembrete_30m_enviado_at")
  cliente                      Cliente?    @relation(fields: [clienteId], references: [id])
  funcionario                  Funcionario @relation(fields: [funcionarioId], references: [id])
  servico                      Servico     @relation(fields: [servicoId], references: [id])

  @@map("agendamentos")
}

model Cliente {
  id           Int           @id @default(autoincrement())
  nome         String
  telefone     String        @unique
  senhaHash    String        @map("senha_hash")
  createdAt    DateTime      @default(now()) @map("created_at")
  agendamentos Agendamento[]
  resetCodes   ResetPasswordCode[]

  @@map("clientes")
}

model ResetPasswordCode {
  id         Int      @id @default(autoincrement())
  clienteId  Int      @map("cliente_id")
  codigo     String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  cliente    Cliente  @relation(fields: [clienteId], references: [id])

  @@map("reset_password_codes")
}
